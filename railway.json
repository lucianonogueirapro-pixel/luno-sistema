{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "cp -r public .next/standalone/public && cp -r .next/static .next/standalone/.next/static && node --max-old-space-size=512 .next/standalone/server.js",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ALWAYS"
  }
}
